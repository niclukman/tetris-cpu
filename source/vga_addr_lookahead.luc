module vga_addr_lookahead (
    input hzcnt[12],
    input vtcnt[12],
    output xblock[5],
    output yblock[5]
) {
    sig next_hzcnt[12]
    sig next_vtcnt[12]
    
    always {
        next_hzcnt = (hzcnt == 799) ? 0 : hzcnt + 1
        next_vtcnt = (hzcnt == 799) ? ((vtcnt == 524) ? 0 : vtcnt + 1) : vtcnt
        
        xblock = next_hzcnt >> 5
        yblock = next_vtcnt >> 5
    }
}